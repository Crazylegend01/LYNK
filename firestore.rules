// ============================================================
// LYNK By Legends — Firestore Security Rules
// Deploy via Firebase Console > Firestore > Rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== HELPER FUNCTIONS ==========
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isSignedIn() && (
        getUserData().role == 'admin' ||
        getUserData().adminRole != null
      );
    }
    function isSuperAdmin() {
      return isSignedIn() && getUserData().adminRole == 'super';
    }
    function isNotSuspended() {
      return !getUserData().get('suspended', false);
    }

    // ========== USERS ==========
    match /users/{userId} {
      // Anyone signed in can read profiles
      allow read: if isSignedIn();
      // Only owner can create/update own profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isSuperAdmin();
      // Only super admin can delete
      allow delete: if isSuperAdmin();
    }

    // ========== POSTS ==========
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotSuspended();
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        isAdmin()
      );

      // Comments sub-collection
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isNotSuspended();
        allow delete: if isSignedIn() && (
          resource.data.authorId == request.auth.uid ||
          isAdmin()
        );
      }
    }

    // ========== FRIENDS ==========
    match /friends/{friendId} {
      allow read: if isSignedIn() && (
        resource.data.from == request.auth.uid ||
        resource.data.to == request.auth.uid
      );
      allow create: if isSignedIn() &&
        request.resource.data.from == request.auth.uid &&
        isNotSuspended();
      allow update: if isSignedIn() && (
        resource.data.to == request.auth.uid ||
        resource.data.from == request.auth.uid
      );
      allow delete: if isSignedIn() && (
        resource.data.from == request.auth.uid ||
        resource.data.to == request.auth.uid
      );
    }

    // ========== CONVERSATIONS ==========
    match /conversations/{convId} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participants;

      // Messages sub-collection
      match /messages/{messageId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants &&
          request.resource.data.senderId == request.auth.uid;
        allow delete: if isSignedIn() &&
          resource.data.senderId == request.auth.uid;
      }
    }

    // ========== COMMUNITIES ==========
    match /communities/{communityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ========== REPORTS ==========
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ========== SECURITY LOGS ==========
    match /securityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    // ========== ADMIN ONLY ==========
    match /adminConfig/{docId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
