rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isSignedIn() && (getUserData().role == 'admin' || getUserData().adminRole != null);
    }
    // Super admin = adminRole 'super' OR a legacy admin with role='admin' but no adminRole sub-type
    function isSuperAdmin() {
      return isSignedIn() && (
        getUserData().adminRole == 'super' ||
        (getUserData().role == 'admin' && getUserData().get('adminRole', null) == null)
      );
    }
    function isNotSuspended() {
      return !getUserData().get('suspended', false);
    }
    function isChangingAdminFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'adminRole']);
    }

    // ===== USERS =====
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if
        isSuperAdmin() ||
        (isOwner(userId) && !isChangingAdminFields()) ||
        (isAdmin() && !isChangingAdminFields());
      allow delete: if isSuperAdmin();
    }

    // ===== POSTS =====
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotSuspended();
      allow update: if isSignedIn() && isNotSuspended() && (
        resource.data.authorId == request.auth.uid ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likes', 'likesCount', 'commentsCount', 'poll'])
      );
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isNotSuspended();
        allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }

    // ===== FRIENDS =====
    match /friends/{friendId} {
      allow read: if isSignedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.from == request.auth.uid && isNotSuspended();
      allow update: if isSignedIn() && (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
    }

    // ===== CONVERSATIONS & MESSAGES =====
    match /conversations/{convId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants && request.resource.data.senderId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    // ===== NOTIFICATIONS =====
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.toUid == request.auth.uid;
      allow create: if isSignedIn() && isNotSuspended();
      allow update: if isSignedIn() && resource.data.toUid == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.toUid == request.auth.uid || isAdmin());
    }

    // ===== USER NOTIFICATIONS (subcollection) =====
    match /users/{userId}/notifications/{notifId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // ===== COMMUNITIES =====
    match /communities/{commId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotSuspended();
      allow update: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && (request.auth.uid == memberId || isAdmin());
      }
    }
    // Flat communityMembers collection used by communities.js
    match /communityMembers/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotSuspended();
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.uid || isAdmin());
    }

    // ===== EVENTS =====
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotSuspended();
      allow update: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }
    match /eventRsvps/{rsvpId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ===== CLUBS =====
    match /clubs/{clubId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotSuspended();
      allow update: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }
    match /clubMembers/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotSuspended();
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.uid || isAdmin());
    }
    match /clubPosts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotSuspended();
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // ===== MARKETPLACE =====
    // Original alias (kept for backward compatibility)
    match /listings/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotSuspended();
      allow update: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    // Actual collection used by marketplace.js
    match /marketplaceListings/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotSuspended();
      allow update: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    // Saved/bookmarked listings — per user
    match /savedListings/{savedId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ===== PUSH QUEUE (FCM) =====
    match /pushQueue/{docId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // ===== SPONSORED POSTS =====
    match /sponsoredPosts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotSuspended();
      allow update: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ===== ANNOUNCEMENTS =====
    match /announcements/{annId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ===== SCHOOLS =====
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== PAYMENT LOGS =====
    match /paymentLogs/{logId} {
      allow read: if isAdmin() || resource.data.uid == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    // ===== PREMIUM =====
    match /premium/{docId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // ===== AI USAGE =====
    match /aiUsage/{docId} {
      allow read, write: if isSignedIn() && docId.matches(request.auth.uid + '_.*');
    }

    match /aiUsageLogs/{docId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    // ===== SETTINGS (AI keys, payment keys) — admin-only read AND write =====
    match /settings/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ===== REPORTS =====
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ===== SECURITY LOGS =====
    match /securityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    // ===== ADMIN CONFIG (both naming conventions) =====
    match /adminConfig/{docId} {
      allow read, write: if isAdmin();
    }
    // snake_case alias used by admin.js (admin_config collection)
    match /admin_config/{docId} {
      allow read, write: if isAdmin();
    }

    // ===== BLOCKS =====
    match /blocks/{blockId} {
      allow read: if isSignedIn() && (resource.data.blockedBy == request.auth.uid || resource.data.blockedUser == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.blockedBy == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.blockedBy == request.auth.uid;
    }
  }
}
