// ============================================================
// LYNK By Legends — Firebase Storage Rules
// PASTE THESE IN: Firebase Console → Storage → Rules → Publish
// ============================================================

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ===== AVATARS =====
    // Only the owner can upload their own avatar, anyone signed in can read
    match /avatars/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ===== COVER PHOTOS =====
    match /covers/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ===== POST MEDIA (images and videos) =====
    match /posts/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // ===== CHAT ATTACHMENTS =====
    match /chat/{convId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // Default: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
